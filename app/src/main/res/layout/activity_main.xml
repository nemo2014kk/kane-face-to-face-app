<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- 中轴线 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- ================== 上半屏 (对方：倒置 180度) ================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_half"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rotation="180"
        android:background="#111111"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top_chat"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="25dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_top_mic" />

        <TextView
            android:id="@+id/btn_top_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="50dp"
            android:layout_marginEnd="15dp"
            android:gravity="center"
            android:text="🎙️\n英"
            android:textColor="#00BCFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================== 下半屏 (我方：正常显示) ================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_half"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1A1A1B"
        app:layout_constraintTop_toBottomOf="@id/guideline_center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bottom_chat"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="25dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_bottom_mic" />

        <TextView
            android:id="@+id/btn_bottom_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="15dp"
            android:gravity="center"
            android:text="🎙️\n中"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= 🌟 赛博胶囊字号控制器 ================= -->
        <LinearLayout
            android:id="@+id/ll_font_control"
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="80dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 与麦克风拉开 120dp 的距离，绝对杜绝防误触 -->
            <TextView
                android:id="@+id/btn_font_plus"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="A+"
                android:textColor="#00E676"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_font_reset"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="◆"
                android:textColor="#00E676"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_font_minus"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="A-"
                android:textColor="#00E676"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
        <!-- ======================================================= -->
        <!-- ================= 🌟 视觉翻译：相机展开组 ================= -->
        <!-- 修改了宽度为 160dp，为向左弹出的动画预留足够的“透明跑道”，防止被系统裁剪 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_camera_group"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="15dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 子按钮1：相册 (初始隐藏) -->
            <TextView
                android:id="@+id/btn_sub_gallery"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🖼️"
                android:textSize="18sp"
                android:visibility="invisible"
                android:alpha="0"
                android:elevation="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- 子按钮2：相机 (初始隐藏) -->
            <TextView
                android:id="@+id/btn_sub_camera"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📸"
                android:textSize="18sp"
                android:visibility="invisible"
                android:alpha="0"
                android:elevation="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- 主按钮：视觉翻译开关 -->
            <TextView
                android:id="@+id/btn_main_camera"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="📷"
                android:textSize="22sp"
                android:elevation="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- ======================================================= -->
        <!-- ======================================================= -->
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================== 中央灵动岛与功能面板 ================== -->
    <TextView
        android:id="@+id/tv_dynamic_island"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨随处心安，沟通无界"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/guideline_center"
        app:layout_constraintBottom_toBottomOf="@id/guideline_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/btn_swap"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="↕️"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/guideline_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_center" />

    <TextView
        android:id="@+id/btn_clear"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="🗑️"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/guideline_center"
        app:layout_constraintStart_toEndOf="@id/btn_swap"
        app:layout_constraintTop_toTopOf="@id/guideline_center" />

    <TextView
        android:id="@+id/btn_keyboard"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="✍️"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/guideline_center"
        app:layout_constraintEnd_toStartOf="@id/btn_settings"
        app:layout_constraintTop_toTopOf="@id/guideline_center" />

    <TextView
        android:id="@+id/btn_settings"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="⚙️"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/guideline_center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_center" />

    <!-- ================== 🌟 赛博全屏大字报 (隐藏图层) ================== -->
    <!-- 覆盖整个屏幕，默认隐藏，超高 Z轴层级 -->
    <FrameLayout
        android:id="@+id/layout_fullscreen_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FA0A0A0A"
        android:visibility="gone"
        android:elevation="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/scroll_fullscreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/ll_fullscreen_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"
                android:paddingTop="120dp"
                android:paddingBottom="120dp"> <!-- 上下加大留白，防止文字被悬浮喇叭挡住 -->

                <TextView
                    android:id="@+id/tv_fullscreen_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="10dp" />
            </LinearLayout>
        </ScrollView>

        <!-- 🌟 改动：独立悬浮的全屏小喇叭按钮，不再随文字滚动 -->
        <TextView
            android:id="@+id/btn_fullscreen_play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:gravity="center"
            android:text="🔊 播放语音"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>